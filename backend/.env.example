# ── AWS Configuration ──────────────────────────────────────────────────────────
AWS_PROFILE=salle-cajas
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=948999370306

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=DEBUG

# ── DynamoDB ───────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=fitness-room-dev
# Uncomment for DynamoDB Local:
# DYNAMODB_ENDPOINT_URL=http://localhost:8001

# ── Cognito ────────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_REPLACE_ME
COGNITO_CLIENT_ID=REPLACE_ME
COGNITO_REGION=us-east-1

# ── Lambda Powertools ──────────────────────────────────────────────────────────
POWERTOOLS_SERVICE_NAME=fitness-room-api
POWERTOOLS_METRICS_NAMESPACE=FitnessRoom
POWERTOOLS_LOG_LEVEL=DEBUG


# ── SES / Notifications ────────────────────────────────────────────────────────
SES_SENDER_EMAIL=noreply@fitness-room.mx
SES_SENDER_NAME=Fitness Room
GYM_PHONE=+52 55 0000 0000
NOTIFICATION_CRITICAL_DAYS=7
NOTIFICATION_WARNING_DAYS=30
