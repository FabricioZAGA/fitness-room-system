# ── AWS Configuration ──────────────────────────────────────────────────────────
AWS_PROFILE=salle-cajas
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=948999370306

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=DEBUG

# ── DynamoDB ───────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=fitness-room-dev
# Uncomment for DynamoDB Local:
