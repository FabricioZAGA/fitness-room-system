    "@tanstack/router-vite-plugin": "^1.82.0",
    "aws-amplify": "^6.9.0",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
