# .envrc — direnv workspace configuration for Fitness Room System
#
# REQUIRES: brew install direnv
# ACTIVATE: direnv allow  (run once after cloning)
#
# When you cd into this directory, direnv will automatically:
#   - Activate the Python virtual environment (backend/.venv)
#   - Switch Node to v22 (via nvm or fnm)
#   - Export all AWS and project environment variables
#   - Add project bin paths to PATH

# ─── Python ─────────────────────────────────────────────────────────────────

VENV_DIR="$(pwd)/backend/.venv"

if [ ! -d "$VENV_DIR" ]; then
  echo "⚠️  Python venv not found. Run: bash setup.sh" >&2
else
  source "$VENV_DIR/bin/activate"
  export VIRTUAL_ENV="$VENV_DIR"
fi

# Add backend src to PYTHONPATH so local imports resolve correctly
export PYTHONPATH="$(pwd)/backend/src:${PYTHONPATH:-}"

# ─── Node.js ─────────────────────────────────────────────────────────────────

# fnm (Fast Node Manager — preferred)
if command -v fnm &>/dev/null; then
  eval "$(fnm env --use-on-cd)"
  fnm use --install-if-missing 2>/dev/null || true

# nvm fallback
elif [ -s "$HOME/.nvm/nvm.sh" ]; then
  \. "$HOME/.nvm/nvm.sh"
  nvm use --silent 2>/dev/null || nvm install --silent 2>/dev/null || true

# Homebrew node fallback
elif command -v node &>/dev/null; then
  : # use whatever node is on PATH
else
  echo "⚠️  Node.js not found. Run: brew install node" >&2
fi

# ─── SSL / Proxy corporativo ─────────────────────────────────────────────────
# pip: confiar en PyPI sin verificar certificado corporativo
export PIP_TRUSTED_HOST="pypi.org pypi.python.org files.pythonhosted.org"
export PIP_INDEX_URL="https://pypi.org/simple"

# ─── AWS ─────────────────────────────────────────────────────────────────────

export AWS_PROFILE="salle-cajas"
export AWS_DEFAULT_REGION="us-west-2"
export AWS_ACCOUNT_ID="948999370306"

# ─── Lambda Powertools (local dev) ───────────────────────────────────────────
export POWERTOOLS_TRACE_DISABLED="true"
export POWERTOOLS_DEV="true"
export LOG_LEVEL="DEBUG"

# ─── Project ─────────────────────────────────────────────────────────────────

export FITNESS_ROOM_ROOT="$(pwd)"
export FITNESS_ROOM_ENV="${FITNESS_ROOM_ENV:-local}"

# Load backend .env if present (values do NOT override existing exports)
if [ -f "$(pwd)/backend/.env" ]; then
  dotenv "$(pwd)/backend/.env"
fi

# ─── PATH additions ──────────────────────────────────────────────────────────

# Make local scripts runnable without ./
PATH_add "$(pwd)/infrastructure/scripts"

# ─── Info ────────────────────────────────────────────────────────────────────

echo "✅ Fitness Room workspace ready"
echo "   Python : $(python --version 2>/dev/null || python3 --version 2>/dev/null || echo 'not found')"
echo "   Node   : $(node --version 2>/dev/null || echo 'not found')"
echo "   pnpm   : $(pnpm --version 2>/dev/null || echo 'not found')"
echo "   AWS    : profile=${AWS_PROFILE} region=${AWS_DEFAULT_REGION}"
